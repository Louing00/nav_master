{
  "name": "atlasgate",
  "version": "1.0.0",
  "private": true,
  "description": "AtlasGate 星渡枢航 - 轻量级自托管系统导航枢纽",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w web\"",
    "build": "npm run build -w web && npm run build -w server",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run start:prod -w server",
    "prisma:generate": "npm run prisma:generate -w server"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "concurrently": "^8.2.2",
    "jsdom": "^24.1.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
