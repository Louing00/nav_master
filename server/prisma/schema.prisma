generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories   Category[]
  apps         App[]
  settings     Setting[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apps        App[]
}

model App {
  id            Int          @id @default(autoincrement())
  name          String
  url           String
  description   String?
  icon          String?
  resolvedIconUrl String?
  iconResolvedAt DateTime?
  categoryId    Int?
  tags          String?
  sortOrder     Int          @default(0)
  visible       Boolean      @default(true)
  openInNewTab  Boolean      @default(true)
  healthStatus  String       @default("unknown")
  healthCheckedAt DateTime?
  healthLatencyMs Int?
  healthError   String?
  healthEnabled Boolean      @default(true)
  userId        Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  features      AppFeature[]

  @@unique([userId, url])
}

model AppFeature {
  id          Int      @id @default(autoincrement())
  appId       Int
  title       String
  description String?
  anchor      String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String
  value     String?
  userId    Int
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}
